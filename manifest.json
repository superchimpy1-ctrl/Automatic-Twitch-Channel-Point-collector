{
  "manifest_version": 3,
  "name": "Twitch Bonus Points Collector",
  "version": "1.1.0",
  "description": "Auto-claims Twitch channel bonus points and tracks your balance.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.twitch.tv/*"],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitch Bonus Points"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "twitch-bonus-points@example.com"
    }
  }
}
